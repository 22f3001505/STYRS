<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".ui.ResultActivity">

    <!-- Header with Logo -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:src="@drawable/logo_socell"
            android:scaleType="fitCenter"
            android:contentDescription="socell logo" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/btnNewScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Image Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp">

                <ImageView
                    android:id="@+id/imageResult"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Result Card -->
            <LinearLayout
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:padding="24dp"
                android:background="@drawable/bg_result_good">

                <TextView
                    android:id="@+id/txtResultIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="48sp" />

                <TextView
                    android:id="@+id/txtResultLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HEALTHY CELL"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_healthy"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txtConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confidence: 94.7%"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Recommendation Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recommendation_title"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/txtRecommendation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Probability Distribution -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/probability_distribution"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="16dp" />

                    <!-- Healthy Progress -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="@string/good_label"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressGood"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:progress="0"
                            app:indicatorColor="@color/status_healthy"
                            app:trackColor="@color/good_light"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="12dp" />

                        <TextView
                            android:id="@+id/txtGoodPercent"
                            android:layout_width="50dp"
                            android:layout_height="wrap_content"
                            android:text="95%"
                            android:textColor="@color/status_healthy"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Defective Progress -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="@string/defective_label"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressDefective"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:progress="0"
                            app:indicatorColor="@color/status_critical"
                            app:trackColor="@color/defective_light"
                            app:trackCornerRadius="4dp"
                            app:trackThickness="12dp" />

                        <TextView
                            android:id="@+id/txtDefectivePercent"
                            android:layout_width="50dp"
                            android:layout_height="wrap_content"
                            android:text="5%"
                            android:textColor="@color/status_critical"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- WhatsApp Support Button (only visible for Defective results) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWhatsApp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Contact Support on WhatsApp"
                android:textSize="15sp"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:backgroundTint="#25D366"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_whatsapp"
                app:iconGravity="textStart"
                app:iconTint="@android:color/white"
                app:iconSize="22dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- New Scan Button (Tech Blue Outline) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNewScan"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:text="@string/new_scan"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="2dp"
        android:textColor="@color/brand_primary"
        app:icon="@drawable/ic_camera"
        app:iconGravity="textStart"
        app:iconTint="@color/brand_primary"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
