<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark theme for socell -->
    <style name="Theme.SolarCellDetector" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/brand_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnPrimary">@color/text_inverse</item>
        <!-- Smooth activity transitions -->
        <item name="android:windowAnimationStyle">@style/WindowAnimationStyle</item>
    </style>

    <!-- Window Transitions -->
    <style name="WindowAnimationStyle">
        <item name="android:activityOpenEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@android:anim/fade_out</item>
    </style>

    <!-- Primary Button (Solar Yellow) -->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_inverse</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Secondary Button (Tech Blue Outline) -->
    <style name="OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_secondary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <!-- Card Styles -->
    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Result Card Styles -->
    <style name="ResultCardGood">
        <item name="android:background">@drawable/bg_result_good</item>
        <item name="android:padding">24dp</item>
    </style>

    <style name="ResultCardDefective">
        <item name="android:background">@drawable/bg_result_defective</item>
        <item name="android:padding">24dp</item>
    </style>

    <!-- Alert Dialog -->
    <style name="AlertDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/bg_elevated</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/AlertDialogPositiveButton</item>
    </style>

    <style name="AlertDialogPositiveButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/status_critical</item>
    </style>
</resources>
